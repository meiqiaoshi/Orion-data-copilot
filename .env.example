# Copy to `.env` in the repo root (never commit `.env`).
# Used by `docker compose` and optional for local shells.

# Optional — enables the OpenAI-backed planner when `use_llm` is true.
# OPENAI_API_KEY=

# Optional — OpenAI model for the LLM planner (default: gpt-5).
# ORION_OPENAI_MODEL=gpt-4o-mini

# Optional — HTTP access log: set to 0/false/no/off to disable (default: on).
# ORION_API_ACCESS_LOG=1

# Optional — slowapi limit for POST /v1/plan and /v1/query (default: 60/minute). Use off/0/false/none to relax.
# ORION_API_RATE_LIMIT_POST=120/minute

# Optional — Streamlit: call a remote API instead of in-process planner (e.g. http://127.0.0.1:8000).
# ORION_API_BASE=http://127.0.0.1:8000

# Optional — when set, HTTP `/v1/plan`, `/v1/query`, and `/v1/version` require
# `X-API-Key` or `Authorization: Bearer`.
# ORION_API_KEY=

# Optional — IngestFlow DuckDB file (default: ./warehouse.duckdb). Useful in Docker.
# ORION_DUCKDB_PATH=/app/warehouse.duckdb
