# Copy to `.env` in the repo root (never commit `.env`).
# Used by `docker compose` and optional for local shells.

# Optional — enables the OpenAI-backed planner when `use_llm` is true.
# OPENAI_API_KEY=

# Optional — when set, HTTP `/v1/query` and `/v1/version` require
# `X-API-Key` or `Authorization: Bearer`.
# ORION_API_KEY=
